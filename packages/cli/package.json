{
  "name": "@borg/cli",
  "version": "2.5.0",
  "type": "module",
  "bin": {
    "borg": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --clear-screen=false src/index.ts start --port 3100",
    "dev:server": "tsx watch --clear-screen=false src/index.ts start --port 3100",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@borg/core": "workspace:*",
    "@trpc/server": "^11.8.1",
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.0.0",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "ink": "^4.4.1",
    "open": "^10.1.0",
    "react": "18.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@borg/tsconfig": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ink-text-input": "^2.0.5",
    "@types/react": "^18.2.0",
    "eslint": "^8.56.0",
    "typescript": "^5.9.3"
  }
}